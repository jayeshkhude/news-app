# NewsLens environment variables (template)
# Copy to `.env` for local dev. For production, set these in your hosting provider dashboard.

# --- Core / Sessions ---
# Use a long random value in production.
FLASK_SECRET_KEY=change-me

# Local dev: keep cookies working on http://localhost.
# Production (HTTPS): set true.
SESSION_COOKIE_SECURE=false

# Optional: restrict API CORS when frontend and backend are on different origins.
# Example: ALLOWED_ORIGINS=http://localhost:5000,https://yourdomain.com
# ALLOWED_ORIGINS=

# --- AI (required for summaries/pipeline) ---
GROQ_API_KEY=change-me

# --- Google Sign-In (required for login / create account) ---
GOOGLE_CLIENT_ID=change-me.apps.googleusercontent.com

# --- Database ---
# Recommended for production: Postgres (any managed provider).
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Local dev fallback: SQLite file path (relative to repo root if you run from there).
SQLITE_DB_PATH=data/news.db

# --- Admin / Security ---
# Protect admin endpoints via `X-Admin-Token` header.
ADMIN_TOKEN=change-me

# Optional: protect /api/cron/run?secret=...
# CRON_SECRET=change-me

# --- Pipeline knobs (optional) ---
MAX_ENTRIES_PER_FEED=40
MAX_SUMMARIES_PER_RUN=5
RUN_PIPELINE_ON_START=0

